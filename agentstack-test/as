#!/usr/bin/env bash
# Run agentstack against the simulated machine in this folder (isolated HOME),
# so nothing touches your real ~/.claude.json etc.
set -euo pipefail
here="$(cd "$(dirname "$0")" && pwd)"
bin="$here/../target/debug/agentstack"
exec env HOME="$here/runtime/home" AGENTSTACK_HOME="$here/runtime/ashome" "$bin" "$@"
