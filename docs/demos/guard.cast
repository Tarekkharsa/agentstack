[0.046, "o", "\r\n\u001b[1mAgentStack — guard demo (asserting)\u001b[0m\r\n\u001b[2mThe agent is working in the-project; every tool call is checked first.\u001b[0m\r\n"]
[2.508, "o", "\r\n\u001b[1m1) A destructive shell command outside the workspace\u001b[0m\r\n"]
[2.509, "o", "\u001b[2m$ rm -rf /opt/acme/data\u001b[0m\r\n"]
[2.704, "o", "  \u001b[32mPASS\u001b[0m rm -rf outside the workspace — blocked\r\n"]
[0.000, "o", "\r\n\u001b[1m2) A history-destroying git command\u001b[0m\r\n"]
[2.508, "o", "\u001b[2m$ git reset --hard HEAD~3\u001b[0m\r\n"]
[2.629, "o", "  \u001b[32mPASS\u001b[0m git reset --hard — blocked\r\n"]
[0.000, "o", "\r\n\u001b[1m3) Reading a secret the machine policy denies\u001b[0m\r\n"]
[2.513, "o", "\u001b[2m$ cat .env\u001b[0m\r\n"]
[2.621, "o", "  \u001b[32mPASS\u001b[0m cat a [policy.filesystem] deny path — blocked\r\n"]
[0.000, "o", "\r\n\u001b[1m4) An ordinary, safe command\u001b[0m\r\n"]
[2.512, "o", "\u001b[2m$ ls -la\u001b[0m\r\n"]
[2.621, "o", "  \u001b[32mPASS\u001b[0m an everyday command — allowed\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "\u001b[1mThe audit log recorded each denial (server=host-guard):\u001b[0m\r\n"]
