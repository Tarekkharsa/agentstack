{"version":3,"term":{"cols":100,"rows":30},"timestamp":1784192120,"command":"bash examples/one-manifest-demo/run-demo.sh","env":{"SHELL":"/bin/zsh"}}
[0.061, "o", "\u001b[1;36m  agentstack — one manifest, every CLI\u001b[0m\r\n\r\n\u001b[1;35m▎ One file, committed to the repo, is the whole team's agent setup:\u001b[0m\r\n"]
[2.509, "o", "\u001b[2m$ cat .agentstack/agentstack.toml\u001b[0m\r\n"]
[2.520, "o", "  # One manifest — the portable source of truth for a whole team's agent setup.\r\n  #\r\n  # This single file is what a human authors and commits. `agentstack apply`\r\n  # compiles it into each CLI's *native* config format — you never hand-edit\r\n  # .mcp.json, .codex/config.toml, or .cursor/mcp.json again, and you never let\r\n  # three tools drift out of sync.\r\n  #\r\n  # Note what is NOT here: any secret value. The manifest holds only a `${REF}`\r\n  # placeholder; the real token is resolved per-machine at render time.\r\n  version = 1\r\n  \r\n  # Fan-out targets: the same declarations below render into all three CLIs.\r\n"]
[0.000, "o", "  [targets]\r\n  default = [\"claude-code\", \"codex\", \"cursor\"]\r\n  \r\n  # One MCP server, declared once. Each adapter emits it in its own native shape\r\n  # (Claude tags `type = \"stdio\"`; Codex uses an [mcp_servers.<name>] table with\r\n  # an env subtable; Cursor infers the transport and omits the tag).\r\n  [servers.github]\r\n  type = \"stdio\"\r\n  command = \"npx\"\r\n  args = [\"-y\", \"@modelcontextprotocol/server-github\"]\r\n"]
[0.000, "o", "  # The secret is a placeholder, never a literal. Resolved at apply time from the\r\n"]
[0.000, "o", "  # environment (env → varlock → OS keychain → .env), fail-closed if unset.\r\n"]
[0.000, "o", "  env = { GITHUB_PERSONAL_ACCESS_TOKEN = \"${GITHUB_TOKEN}\" }\r\n"]
[0.000, "o", "  \r\n  # One portable instruction fragment. It compiles into each harness's native\r\n"]
[0.000, "o", "  # instructions file (CLAUDE.md for Claude Code; AGENTS.md for Codex, which\r\n  # Cursor also reads) inside a managed marker block.\r\n  [instructions.guardrails]\r\n  path = \"team-guardrails.md\"\r\n  \r\n  [profiles.default]\r\n  servers = [\"github\"]\r\n"]
[0.001, "o", "  \u001b[2mIt targets three CLIs, declares one MCP server, one instruction fragment,\u001b[0m\r\n"]
[0.000, "o", "  \u001b[2mand references the token only as ${GITHUB_TOKEN} — no secret value here.\u001b[0m\r\n\r\n"]
[0.000, "o", "\u001b[1;35m▎ Prove the portable artifact is secret-free before we render anything:\u001b[0m\r\n"]
[2.512, "o", "\u001b[2m$ grep GITHUB_TOKEN .agentstack/agentstack.toml\u001b[0m\r\n"]
[2.527, "o", "  25:env = { GITHUB_PERSONAL_ACCESS_TOKEN = \"${GITHUB_TOKEN}\" }\r\n"]
[0.022, "o", "  \u001b[32mPASS\u001b[0m the manifest holds the ${GITHUB_TOKEN} placeholder, not the value\r\n"]
[0.028, "o", "\r\n\u001b[1;35m▎ Preview the render — one manifest, three CLIs' native configs, three paths:\u001b[0m\r\n"]
[2.516, "o", "\u001b[2m$ agentstack apply --scope project        # read-only; writes nothing\u001b[0m\r\n"]
[2.540, "o", "  Scope: project\r\n"]
[0.001, "o", "  \r\n  \u001b[1mClaude Code\u001b[0m (/var/folders/4j/46lq80yj25xcdzsrdwtr13y4k4htfx/T/tmp.F5oRQBeasZ/project/.mcp.json)\r\n"]
[0.001, "o", "    \u001b[32m+ {\u001b[39m\r\n    \u001b[32m+   \"mcpServers\": {\u001b[39m\r\n    \u001b[32m+     \"github\": {\u001b[39m\r\n    \u001b[32m+       \"type\": \"stdio\",\u001b[39m\r\n    \u001b[32m+       \"command\": \"npx\",\u001b[39m\r\n    \u001b[32m+       \"args\": [\u001b[39m\r\n    \u001b[32m+         \"-y\",\u001b[39m\r\n    \u001b[32m+         \"@modelcontextprotocol/server-github\"\u001b[39m\r\n    \u001b[32m+       ],\u001b[39m\r\n"]
[0.000, "o", "    \u001b[32m+       \"env\": {\u001b[39m\r\n    \u001b[32m+         \"GITHUB_PERSONAL_ACCESS_TOKEN\": \"${GITHUB_TOKEN}\"\u001b[39m\r\n    \u001b[32m+       }\u001b[39m\r\n    \u001b[32m+     }\u001b[39m\r\n    \u001b[32m+   }\u001b[39m\r\n    \u001b[32m+ }\u001b[39m\r\n    \u001b[36m→\u001b[39m 1 server(s) to apply\r\n"]
[0.000, "o", "    \u001b[2m·\u001b[0m instructions → /var/folders/4j/46lq80yj25xcdzsrdwtr13y4k4htfx/T/tmp.F5oRQBeasZ/project/CLAUDE.md\r\n    \u001b[32m+ <!-- agentstack:start -->\u001b[39m\r\n    \u001b[32m+ Run the project's formatter and linter before proposing any diff.\u001b[39m\r\n"]
[0.000, "o", "    \u001b[32m+ Never paste real secret values into code or config; reference them as `${REF}` placeholders.\u001b[39m\r\n    \u001b[32m+ <!-- agentstack:end -->\u001b[39m\r\n    \u001b[36m→\u001b[39m 1 instruction fragment(s) to apply\r\n"]
[0.000, "o", "  \r\n  \u001b[1mCodex CLI\u001b[0m (/var/folders/4j/46lq80yj25xcdzsrdwtr13y4k4htfx/T/tmp.F5oRQBeasZ/project/.codex/config.toml)\r\n"]
[0.000, "o", "    \u001b[32m+ [mcp_servers.github]\u001b[39m\r\n    \u001b[32m+ command = \"npx\"\u001b[39m\r\n    \u001b[32m+ args = [\"-y\", \"@modelcontextprotocol/server-github\"]\u001b[39m\r\n    \u001b[32m+ \u001b[39m\r\n    \u001b[32m+ [mcp_servers.github.env]\u001b[39m\r\n"]
[0.000, "o", "    \u001b[32m+ GITHUB_PERSONAL_ACCESS_TOKEN = \"${GITHUB_TOKEN}\"\u001b[39m\r\n    \u001b[36m→\u001b[39m 1 server(s) to apply\r\n"]
[0.000, "o", "    \u001b[2m·\u001b[0m instructions → /var/folders/4j/46lq80yj25xcdzsrdwtr13y4k4htfx/T/tmp.F5oRQBeasZ/project/AGENTS.md\r\n    \u001b[32m+ <!-- agentstack:start -->\u001b[39m\r\n    \u001b[32m+ Run the project's formatter and linter before proposing any diff.\u001b[39m\r\n    \u001b[32m+ Never paste real secret values into code or config; reference them as `${REF}` placeholders.\u001b[39m\r\n    \u001b[32m+ <!-- agentstack:end -->\u001b[39m\r\n    \u001b[36m→\u001b[39m 1 instruction fragment(s) to apply\r\n"]
[0.000, "o", "  \r\n  \u001b[1mCursor\u001b[0m (/var/folders/4j/46lq80yj25xcdzsrdwtr13y4k4htfx/T/tmp.F5oRQBeasZ/project/.cursor/mcp.json)\r\n"]
[0.000, "o", "    \u001b[32m+ {\u001b[39m\r\n    \u001b[32m+   \"mcpServers\": {\u001b[39m\r\n    \u001b[32m+     \"github\": {\u001b[39m\r\n    \u001b[32m+       \"command\": \"npx\",\u001b[39m\r\n    \u001b[32m+       \"args\": [\u001b[39m\r\n    \u001b[32m+         \"-y\",\u001b[39m\r\n    \u001b[32m+         \"@modelcontextprotocol/server-github\"\u001b[39m\r\n    \u001b[32m+       ],\u001b[39m\r\n    \u001b[32m+       \"env\": {\u001b[39m\r\n    \u001b[32m+         \"GITHUB_PERSONAL_ACCESS_TOKEN\": \"${GITHUB_TOKEN}\"\u001b[39m\r\n    \u001b[32m+       }\u001b[39m\r\n    \u001b[32m+     }\u001b[39m\r\n    \u001b[32m+   }\u001b[39m\r\n    \u001b[32m+ }\u001b[39m\r\n    \u001b[36m→\u001b[39m 1 server(s) to apply\r\n  \r\n  5 target(s) would change. Re-run with \u001b[1m--write\u001b[0m to write.\r\n"]
[0.002, "o", "  \u001b[2mThe preview MASKS the secret as ${GITHUB_TOKEN} in every diff.\u001b[0m\r\n"]
[0.000, "o", "\r\n\u001b[1;35m▎ Now apply for real (token resolved from this machine's environment):\u001b[0m\r\n"]
[2.512, "o", "\u001b[2m$ GITHUB_TOKEN=… agentstack apply --scope project --write\u001b[0m\r\n"]
[2.549, "o", "  \u001b[2mdone — here is what landed on disk:\u001b[0m\r\n\u001b[2m$ tree of rendered native files\u001b[0m\r\n"]
[2.537, "o", "  .codex/config.toml\r\n  .cursor/mcp.json\r\n  .mcp.json\r\n  AGENTS.md\r\n  CLAUDE.md\r\n"]
[0.000, "o", "\r\n\u001b[1;35m▎ Same server, three native shapes — Claude tags it, Codex sub-tables it, Cursor infers it:\u001b[0m\r\n"]
[2.512, "o", "\u001b[2m$ cat .mcp.json .codex/config.toml .cursor/mcp.json\u001b[0m\r\n"]
[2.508, "o", "  \u001b[1m.mcp.json\u001b[0m\r\n"]
[0.013, "o", "    {\r\n      \"mcpServers\": {\r\n        \"github\": {\r\n          \"type\": \"stdio\",\r\n          \"command\": \"npx\",\r\n          \"args\": [\r\n            \"-y\",\r\n            \"@modelcontextprotocol/server-github\"\r\n          ],\r\n          \"env\": {\r\n            \"GITHUB_PERSONAL_ACCESS_TOKEN\": \"ghp-demo-FAKE-not-a-real-secret-0000\"\r\n          }\r\n"]
[0.000, "o", "        }\r\n      }\r\n    }\r\n"]
[0.001, "o", "  \u001b[1m.codex/config.toml\u001b[0m\r\n"]
[0.010, "o", "    [mcp_servers.github]\r\n    command = \"npx\"\r\n    args = [\"-y\", \"@modelcontextprotocol/server-github\"]\r\n    \r\n    [mcp_servers.github.env]\r\n    GITHUB_PERSONAL_ACCESS_TOKEN = \"ghp-demo-FAKE-not-a-real-secret-0000\"\r\n"]
[0.000, "o", "  \u001b[1m.cursor/mcp.json\u001b[0m\r\n"]
[0.010, "o", "    {\r\n      \"mcpServers\": {\r\n        \"github\": {\r\n          \"command\": \"npx\",\r\n          \"args\": [\r\n            \"-y\",\r\n            \"@modelcontextprotocol/server-github\"\r\n"]
[0.000, "o", "          ],\r\n          \"env\": {\r\n            \"GITHUB_PERSONAL_ACCESS_TOKEN\": \"ghp-demo-FAKE-not-a-real-secret-0000\"\r\n          }\r\n        }\r\n"]
[0.000, "o", "      }\r\n    }\r\n"]
[0.000, "o", "\r\n\u001b[1;35m▎ The story on secrets, honestly:\u001b[0m\r\n"]
[2.516, "o", "  \u001b[2mthe MANIFEST never holds the value; the rendered NATIVE configs DO — those\u001b[0m\r\n  \u001b[2mformats store plaintext, so the resolved token is now on disk in each one.\u001b[0m\r\n"]
[0.000, "o", "\r\n\u001b[1mAsserting the outcome:\u001b[0m\r\n"]
[0.001, "o", "  \u001b[32mPASS\u001b[0m rendered .mcp.json\r\n"]
[0.000, "o", "  \u001b[32mPASS\u001b[0m rendered .codex/config.toml\r\n"]
[0.000, "o", "  \u001b[32mPASS\u001b[0m rendered .cursor/mcp.json\r\n"]
[0.014, "o", "  \u001b[32mPASS\u001b[0m .mcp.json declares the github server\r\n"]
[0.013, "o", "  \u001b[32mPASS\u001b[0m .codex/config.toml declares the github server\r\n"]
[0.013, "o", "  \u001b[32mPASS\u001b[0m .cursor/mcp.json declares the github server\r\n"]
[0.011, "o", "  \u001b[32mPASS\u001b[0m the instruction fragment compiled into CLAUDE.md (Claude Code)\r\n"]
[0.011, "o", "  \u001b[32mPASS\u001b[0m the instruction fragment compiled into AGENTS.md (Codex + Cursor)\r\n"]
[0.011, "o", "  \u001b[32mPASS\u001b[0m .mcp.json holds the resolved token (native formats store plaintext)\r\n"]
[0.010, "o", "  \u001b[32mPASS\u001b[0m .codex/config.toml holds the resolved token (native formats store plaintext)\r\n"]
[0.009, "o", "  \u001b[32mPASS\u001b[0m .cursor/mcp.json holds the resolved token (native formats store plaintext)\r\n"]
[0.014, "o", "  \u001b[32mPASS\u001b[0m the manifest and lockfile never hold the resolved token\r\n"]
[0.000, "o", "\r\n\u001b[1;35m▎ One manifest in. Three CLIs configured, in sync, in their own formats. Secret resolved per-machine.\u001b[0m\r\n"]
[2.508, "o", "\r\n\u001b[1mSummary:\u001b[0m 13 passed, 0 failed\r\n"]
[0.022, "x", "0"]
